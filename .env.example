# ============================================================
# CF-TGBed 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================================

# 必填 - 域名
DOMAIN=img.example.com

# 必填 - Telegram
TG_BOT_TOKEN=123456:ABC-DEF-GHI-JKL-MNO
TG_CHAT_ID=-1001234567890

# 认证
USERNAME=admin
PASSWORD=your-password
ENABLE_AUTH=true
COOKIE=7

# 文件限制
MAX_SIZE_MB=20

# R2（可选）
ENABLE_R2_FALLBACK=true

# GitHub（可选）
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_REPO=username/repo
GITHUB_BRANCH=main
GITHUB_PATH=images
